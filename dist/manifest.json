{
  "manifest_version": 3,
  "name": "Cipher - AI Legal Compliance Guide",
  "version": "1.0.0",
  "description": "Your Personal Super AI Police - Navigate AI laws, data protection regulations, and digital rights with intelligent guidance.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cipher - AI Legal Guide",
    "default_icons": {
      "16": "public/ChatGPT Image Nov 19, 2025 at 12_33_15 AM.png",
      "48": "public/ChatGPT Image Nov 19, 2025 at 12_33_15 AM.png",
      "128": "public/ChatGPT Image Nov 19, 2025 at 12_33_15 AM.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/content.ts"
      ]
    }
  ],
  "icons": {
    "16": "public/ChatGPT Image Nov 19, 2025 at 12_33_15 AM.png",
    "48": "public/ChatGPT Image Nov 19, 2025 at 12_33_15 AM.png",
    "128": "public/ChatGPT Image Nov 19, 2025 at 12_33_15 AM.png"
  }
}
